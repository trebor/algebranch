{
  "permissions": {
    "allow": [
      "Bash(npx eslint:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run lint)",
      "Bash(npx tsc:*)",
      "Bash(npm run type-check:*)",
      "Bash(npm run type-check)",
      "Bash(npm run test:*)",
      "Bash(npm run test)",
      "Bash(npm test:*)",
      "Bash(npm test)",
      "Bash(npm run build:*)",
      "Bash(npm run build)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-edits-on-protected-branch.sh\"",
            "statusMessage": "Checking branch-first policy…"
          }
        ]
      }
    ]
  }
}
