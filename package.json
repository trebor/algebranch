{
  "name": "algebranch-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Interactive Algebraic Derivation Monorepo",
  "workspaces": [
    "math-engine",
    "ui"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=ui",
    "dev:lan": "npx --workspace=ui next dev --webpack -H 0.0.0.0",
    "build": "npm run build --workspace=math-engine && npm run build --workspace=ui",
    "test": "npm run test --workspace=math-engine",
    "lint": "npm run lint --workspace=ui",
    "prepare": "npm run build --workspace=math-engine"
  }
}
