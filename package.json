{
  "name": "algebranch-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Interactive Algebraic Derivation Monorepo",
  "license": "GPL-3.0-or-later",
  "author": "Robert Harris",
  "workspaces": [
    "math-engine",
    "ui"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=ui",
    "start": "npm run start --workspace=ui",
    "dev:lan": "npx --workspace=ui next dev --webpack -H 0.0.0.0",
    "start:lan": "npx --workspace=ui next start -H 0.0.0.0",
    "build": "npm run build --workspace=math-engine && npm run build --workspace=ui",
    "test": "npm run test --workspace=math-engine && npm run test --workspace=ui",
    "lint": "npm run lint --workspace=ui",
    "type-check": "npm run type-check --workspace=math-engine && npm run type-check --workspace=ui",
    "prepare": "npm run build --workspace=math-engine",
    "shoot": "node scripts/shoot.mjs",
    "shoot:hero": "node scripts/shoot-hero.mjs",
    "build-logos": "node scripts/build_logos.mjs",
    "build-social-preview": "node scripts/build_social_preview.mjs"
  },
  "devDependencies": {
    "playwright": "1.60.0"
  }
}
